{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "record_type",
    "privacy",
    "attachment_type",
    "source_id",
    "file_id",
    "resolution_status",
    "source_ids",
    "summary"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z]+(\\.[a-z0-9-]+)+$"},
    "record_type": {"const": "attachment"},
    "privacy": {"type": "string", "enum": ["public", "private", "sensitive"]},
    "attachment_type": {"type": "string", "enum": ["note_embed", "linked_file", "mail_attachment"]},
    "source_id": {"type": "string"},
    "file_id": {"type": "string"},
    "resolution_status": {"type": "string", "enum": ["found", "missing", "external", "unsupported", "ambiguous"]},
    "summary": {"type": "string"},
    "source_ids": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string"},
    "synthetic": {"type": "boolean"}
  },
  "not": {
    "anyOf": [
      {"required": ["content"]},
      {"required": ["content_b64"]},
      {"required": ["content_bytes"]},
      {"required": ["path"]}
    ]
  }
}
