{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "record_type",
    "privacy",
    "file_type",
    "sha256",
    "size_bytes",
    "mime_type",
    "storage_ref",
    "source_ids",
    "summary"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z]+(\\.[a-z0-9-]+)+$"},
    "record_type": {"const": "file"},
    "privacy": {"type": "string", "enum": ["public", "private", "sensitive"]},
    "file_type": {"type": "string", "enum": ["attachment", "document", "image", "audio", "video"]},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "size_bytes": {"type": "integer", "minimum": 0},
    "mime_type": {"type": "string"},
    "storage_ref": {"type": "string", "pattern": "^blob://sha256/[a-f0-9]{64}$"},
    "object_path": {"type": "string", "pattern": "^objects/sha256/[a-f0-9]{2}/[a-f0-9]{64}\\.[A-Za-z0-9]+$"},
    "summary": {"type": "string"},
    "source_ids": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string"},
    "synthetic": {"type": "boolean"}
  },
  "not": {
    "anyOf": [
      {"required": ["content"]},
      {"required": ["content_b64"]},
      {"required": ["content_bytes"]},
      {"required": ["path"]}
    ]
  }
}
