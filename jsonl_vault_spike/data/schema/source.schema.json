{
  "required": [
    "id",
    "record_type",
    "summary",
    "privacy",
    "locator",
    "captured_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z]+(\\.[a-z0-9-]+)+$"
    },
    "summary": {
      "type": "string"
    },
    "privacy": {
      "type": "string",
      "enum": [
        "public",
        "private",
        "sensitive"
      ]
    },
    "locator": {
      "type": "object"
    },
    "captured_at": {
      "type": "string"
    },
    "hash": {
      "type": "string"
    },
    "record_type": {
      "const": "source",
      "description": "Technical JSONL record discriminator. Use domain-specific fields such as entity_type, source_type, relation_type, task_type, or vault_type for subtypes."
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false
}
