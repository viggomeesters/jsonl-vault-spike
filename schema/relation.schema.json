{
  "required": [
    "id",
    "record_type",
    "privacy",
    "subject_id",
    "relation_type",
    "object_id",
    "source_ids"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z]+(\\.[a-z0-9-]+)+$"
    },
    "summary": {
      "type": "string"
    },
    "privacy": {
      "type": "string",
      "enum": [
        "public",
        "private",
        "sensitive"
      ]
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "record_type": {
      "const": "relation",
      "description": "Technical JSONL record discriminator. Use domain-specific subtype fields where applicable, such as entity_type, source_type, relation_type, task_type, claim_type, or vault_type."
    },
    "subject_id": {
      "type": "string"
    },
    "relation_type": {
      "type": "string"
    },
    "object_id": {
      "type": "string"
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false
}
